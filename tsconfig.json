{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "paths": {
      "@apicraft/core": ["./packages/core/src"],
      "@apicraft/generator-openapi": ["./packages/generators/openapi/src"],
      "@apicraft/generator-client": ["./packages/generators/client/src"],
      "@apicraft/generator-react": ["./packages/generators/react/src"],
      "@apicraft/generator-zod": ["./packages/generators/zod/src"],
      "@apicraft/generator-docs": ["./packages/generators/docs/src"],
      "@apicraft/adapter-express": ["./packages/adapters/express/src"],
      "@apicraft/adapter-fastify": ["./packages/adapters/fastify/src"],
      "@apicraft/adapter-hono": ["./packages/adapters/hono/src"],
      "@apicraft/adapter-next": ["./packages/adapters/next/src"],
      "@apicraft/adapter-koa": ["./packages/adapters/koa/src"],
      "@apicraft/adapter-nest": ["./packages/adapters/nest/src"],
      "@apicraft/middleware-auth": ["./packages/middleware/auth/src"],
      "@apicraft/middleware-rate-limiter": ["./packages/middleware/rate-limiter/src"],
      "@apicraft/middleware-logger": ["./packages/middleware/logger/src"],
      "@apicraft/middleware-cors": ["./packages/middleware/cors/src"],
      "@apicraft/middleware-compression": ["./packages/middleware/compression/src"],
      "@apicraft/middleware-helmet": ["./packages/middleware/helmet/src"],
      "@apicraft/cli": ["./packages/cli/src"]
    }
  },
  "include": ["src", "packages/*/src", "packages/*/*/src", "apicraft.config.ts"],
  "exclude": ["node_modules", "dist", "packages/create-apicraft"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/generators/openapi" },
    { "path": "packages/generators/client" },
    { "path": "packages/generators/react" },
    { "path": "packages/generators/zod" },
    { "path": "packages/generators/docs" },
    { "path": "packages/adapters/express" },
    { "path": "packages/adapters/fastify" },
    { "path": "packages/adapters/hono" },
    { "path": "packages/adapters/next" },
    { "path": "packages/adapters/koa" },
    { "path": "packages/adapters/nest" },
    { "path": "packages/middleware/auth" },
    { "path": "packages/middleware/rate-limiter" },
    { "path": "packages/middleware/logger" },
    { "path": "packages/middleware/cors" },
    { "path": "packages/middleware/compression" },
    { "path": "packages/middleware/helmet" },
    { "path": "packages/cli" }
  ]
}